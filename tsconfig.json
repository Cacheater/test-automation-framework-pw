{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "bundler",
    "types": [
      "node",
      "@playwright/test"
    ],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@pages/*": [
        "tests/pages/*"
      ],
      "@support/*": [
        "tests/support/*"
      ]
    }
  },
  "include": [
    "playwright.config.ts",
    "tests/**/*.ts"
  ]
}
