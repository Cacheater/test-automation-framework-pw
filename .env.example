# GitHub Token for MCP Integration
# Para obtener tu token:
# 1. Ve a https://github.com/settings/tokens
# 2. Click en "Generate new token (classic)"
# 3. Selecciona scopes: repo, read:user, read:org
# 4. Copia el token y pégalo aquí

GITHUB_TOKEN=your_github_token_here

# Opcional: Configuración base de tests
BASE_URL=https://www.globalsqa.com/angularJs-protractor/BankingProject/#/login
